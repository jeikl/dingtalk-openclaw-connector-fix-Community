            }
          }
        },
        "additionalProperties": false
      },
      "uiHints": {
        "channels.dingtalk-connector.clientId": {
          "label": "Client ID (AppKey)",
          "help": "钉钉应用的 AppKey / Client ID",
          "sensitive": true
        },
        "channels.dingtalk-connector.clientSecret": {
          "label": "Client Secret (AppSecret)",
          "help": "钉钉应用的 AppSecret / Client Secret",
          "sensitive": true
        },
        "channels.dingtalk-connector.dmPolicy": {
          "label": "DM Policy",
          "help": "单聊策略：open（开放）、pairing（配对）、allowlist（白名单）"
        },
        "channels.dingtalk-connector.groupPolicy": {
          "label": "Group Policy",
          "help": "群聊策略：open（开放）、allowlist（白名单）、disabled（禁用）"
        },
        "channels.dingtalk-connector.requireMention": {
          "label": "Require @Mention",
          "help": "群聊中是否需要 @机器人 才响应"
        },
        "channels.dingtalk-connector.debug": {
          "label": "Debug Mode",
          "help": "启用调试日志",
          "advanced": true
        },
        "channels.dingtalk-connector.messageImageMd": {
          "label": "Message Image Markdown Merge",
          "help": "message 工具图文策略。false（默认）：文字与图片分开发送，阅读体验更好。true：仅当多图与文字结合时合并为一条 markdown；单张图文、纯媒体仍分开。",
          "advanced": true
        },
        "channels.dingtalk-connector.messageAnswerCard": {
          "label": "Message Answer Card",
          "help": "message 工具是否用答案卡发正文。默认开启（答案静态卡，失败降级普通消息）；设为 false 则直接发 text/markdown。与会话流式的 answerCard 独立。",
          "advanced": true
        },
        "channels.dingtalk-connector.groupReplyMode": {
          "label": "Group Reply Mode",
          "help": "群回复形态：aicard（默认，流式 AI 卡）/ text / markdown。text、markdown 时群聊不用 AI 卡，便于多机器人互相 @。",
          "advanced": true
        },
        "channels.dingtalk-connector.cardTemplateId": {
          "label": "AI Card Template ID",
          "help": "会话流式 AI Card 模板 ID；不填默认 0d2c84b3-12c1-473b-b14a-f329a7a102cd.schema。",
          "advanced": true
        },
        "channels.dingtalk-connector.cardContentVar": {
          "label": "Card Content Variable",
          "help": "流式卡内容变量名，默认 content（过程/工具/终稿写入此字段）。",
          "advanced": true
        },
        "channels.dingtalk-connector.answerCard": {
          "label": "Session Answer Card",
          "help": "会话流式答案卡开关，默认开启。长答案另开静态卡，原卡定格思考完成；显式 false 关闭。",
          "advanced": true
        },
        "channels.dingtalk-connector.answerActToken": {
          "label": "Answer Card Token Threshold",
          "help": "会话答案卡触发阈值（token），默认 500。≤ 阈值在原卡定稿；> 阈值才新建答案卡。",
          "advanced": true
        },
        "channels.dingtalk-connector.answerCardTemplateId": {
          "label": "Answer Card Template ID",
          "help": "答案静态卡模板 ID；message 答案卡与会话答案卡共用。不填用内置默认模板。",
          "advanced": true
        },
        "channels.dingtalk-connector.endpoint": {
          "label": "Gateway Endpoint",
          "help": "自定义 DWClient 网关地址（高级）",
          "advanced": true
        },
        "channels.dingtalk-connector.accounts": {
          "label": "Accounts",
          "help": "多账号配置，每个 key 是账号 ID"
        }
      }
    }
  }
}
